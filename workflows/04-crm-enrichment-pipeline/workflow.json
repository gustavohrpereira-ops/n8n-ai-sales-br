{
  "name": "04 - CRM Enrichment Pipeline",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "crm-enrich"
      },
      "id": "webhook-crm",
      "name": "Webhook - Novo Contato CRM",
      "type": "n8n-nodes-base.webhook",
      "position": [250, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://receitaws.com.br/v1/cnpj/{{ $json.body.cnpj.replace(/[^0-9]/g, '') }}"
      },
      "id": "cnpj-lookup",
      "name": "Consulta CNPJ (ReceitaWS)",
      "type": "n8n-nodes-base.httpRequest",
      "position": [450, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key", "value": "YOUR_ANTHROPIC_API_KEY" },
            { "name": "anthropic-version", "value": "2023-06-01" },
            { "name": "content-type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "model", "value": "claude-opus-4-5" },
            { "name": "max_tokens", "value": "800" },
            { "name": "messages", "value": "=[{\"role\":\"user\",\"content\":\"Voce e especialista em vendas de consorcio. Com base nos dados deste contato, retorne APENAS JSON valido com: { perfil_financeiro: string, melhor_produto: string, objecoes_provaveis: string[], abordagem_recomendada: string, score_potencial: number }\\n\\nDados: Nome={{ $json.body.nome }}, Empresa={{ $json.body.empresa }}, Cargo={{ $json.body.cargo }}, Cidade={{ $json.body.cidade }}, Origem={{ $json.body.origem }}\"}]" }
          ]
        }
      },
      "id": "claude-enrich",
      "name": "Claude - Enriquece Perfil",
      "type": "n8n-nodes-base.httpRequest",
      "position": [450, 400]
    },
    {
      "parameters": {
        "jsCode": "const claudeResp = $('Claude - Enriquece Perfil').first().json;\nconst content = claudeResp.content[0].text;\nlet enriched;\ntry { enriched = JSON.parse(content); } catch(e) { const m = content.match(/\\{[\\s\\S]*\\}/); enriched = m ? JSON.parse(m[0]) : {}; }\nconst lead = $('Webhook - Novo Contato CRM').first().json.body;\nreturn [{ json: { ...lead, ...enriched, enriquecido_em: new Date().toISOString() } }];"
      },
      "id": "merge-data",
      "name": "Consolida Dados Enriquecidos",
      "type": "n8n-nodes-base.code",
      "position": [650, 400]
    },
    {
      "parameters": {
        "operation": "append",
        "documentId": { "value": "YOUR_SHEET_ID" },
        "sheetName": "CRM",
        "columns": { "mappingMode": "autoMapInputData" }
      },
      "id": "save-crm",
      "name": "Salva no CRM (Sheets)",
      "type": "n8n-nodes-base.googleSheets",
      "position": [850, 400]
    }
  ],
  "connections": {
    "Webhook - Novo Contato CRM": { "main": [[{ "node": "Claude - Enriquece Perfil" }]] },
    "Claude - Enriquece Perfil": { "main": [[{ "node": "Consolida Dados Enriquecidos" }]] },
    "Consolida Dados Enriquecidos": { "main": [[{ "node": "Salva no CRM (Sheets)" }]] }
  }
}
